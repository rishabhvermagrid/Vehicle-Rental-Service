    {
      "name": "Error Cases",
      "description": "Requests that should return errors — useful for verifying role enforcement and validation",
      "item": [
        {
          "name": "Unauthenticated — No Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/vehicles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vehicles"]
            },
            "description": "Call this BEFORE logging in (or after logging out).\n\nExpected: 401 — No active session."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message present', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Validation Error — Missing Fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Toyota\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/vehicles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vehicles"]
            },
            "description": "Expected: 400 with per-field validation errors map."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Validation errors returned', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.equal('Validation failed');",
                  "    pm.expect(body.data).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
