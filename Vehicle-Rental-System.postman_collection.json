    {
      "name": "Bookings",
      "description": "Booking management endpoints — all go through API Gateway which validates session and injects role headers automatically.\n\n**Flow:** Login → Create a Vehicle (ADMIN) → Create Booking (any role) → Cancel or Complete",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": {{vehicleId}},\n  \"startDate\": \"2026-07-10\",\n  \"endDate\": \"2026-07-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"]
            },
            "description": "Create a new booking.\n\n**Required role:** ADMIN, STAFF, or CUSTOMER\n\n- CUSTOMER: omit `customerId` — it is taken from your session automatically\n- ADMIN/STAFF: include `customerId` to book on behalf of a customer\n\n`totalDays` and `totalAmount` are calculated server-side.\n\nVehicle must have status `AVAILABLE`. It will be set to `BOOKED` after creation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Booking created', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "    pm.expect(body.data.status).to.equal('PENDING');",
                  "    pm.expect(body.data.totalDays).to.be.a('number');",
                  "    pm.expect(body.data.totalAmount).to.be.a('number');",
                  "    pm.collectionVariables.set('bookingId', body.data.id);",
                  "    console.log('Created booking id:', body.data.id, '| Total:', body.data.totalAmount);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Booking — Staff books for Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": {{vehicleId}},\n  \"customerId\": {{userId}},\n  \"startDate\": \"2026-08-01\",\n  \"endDate\": \"2026-08-05\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"]
            },
            "description": "ADMIN or STAFF booking on behalf of a customer.\n\n`customerId` is required here — the service uses it instead of the session user ID.\n\nLogin as ADMIN or STAFF before using this request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
