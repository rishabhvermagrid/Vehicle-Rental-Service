{
  "info": {
    "_postman_id": "vrs-collection-2024",
    "name": "Vehicle Rental System",
    "description": "Complete API collection for Vehicle Rental System.\n\n**Base URL:** http://localhost:8080\n\n**Flow:**\n1. Run `docker-compose up --build` from the project root\n2. Register → Login → Test endpoints\n3. Postman handles the SESSION cookie automatically after login\n\n**Roles:** ADMIN · STAFF · CUSTOMER\nSeed ADMIN via MySQL: `UPDATE users SET role = 'ADMIN' WHERE email = 'your@email.com';`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "API Gateway URL — all requests go here"
    },
    {
      "key": "vehicleId",
      "value": "1",
      "type": "string",
      "description": "Auto-set by Create Vehicle test script"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string",
      "description": "Auto-set by Login test script"
    },
    {
      "key": "bookingId",
      "value": "1",
      "type": "string",
      "description": "Auto-set by Create Booking test script"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — no SESSION cookie required for register/login",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user. Default role is CUSTOMER.\n\nTo make this user ADMIN, run in MySQL:\n```sql\nUPDATE users SET role = 'ADMIN' WHERE email = 'john@example.com';\n```\nThen logout and login again."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Success is true', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "    pm.expect(body.data.role).to.equal('CUSTOMER');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login and receive a SESSION cookie. Postman stores it automatically — all subsequent requests use it without any manual setup."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Login successful', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "    if (body.data && body.data.id) {",
                  "        pm.collectionVariables.set('userId', body.data.id);",
                  "        console.log('Logged in as:', body.data.email, '| Role:', body.data.role);",
                  "    }",
                  "});",
                  "pm.test('SESSION_ID cookie set', () => {",
                  "    pm.expect(pm.cookies.has('SESSION_ID')).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Returns the currently logged-in user's details. Requires active session."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns user data', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.have.property('email');",
                  "    pm.expect(body.data).to.have.property('role');",
                  "    console.log('Current user role:', body.data.role);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Validate Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/validate",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "validate"]
            },
            "description": "Returns true if the current session is alive, false if expired. This is also what the API Gateway calls internally on every request to /api/**."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Session is valid', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"secret123\",\n  \"newPassword\": \"newSecret456\",\n  \"confirmNewPassword\": \"newSecret456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Changes the password. Session is invalidated after this — you must login again with the new password."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Password changed', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Invalidates the current session. The SESSION cookie is cleared."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Logged out', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "description": "User management endpoints — ADMIN role required",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"]
            },
            "description": "Returns all registered users. ADMIN role required.\n\nNote: These requests go directly to auth-service through the gateway — no X-User headers are injected because the gateway bypasses auth for /admin/** routes. Auth-service uses its own Spring Security session to enforce the ADMIN role here."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns user list', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an('array');",
                  "    if (body.data.length > 0) {",
                  "        pm.collectionVariables.set('userId', body.data[0].id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Assign Role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"STAFF\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/role",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "role"]
            },
            "description": "Assign a role to a user. Allowed values: ADMIN, STAFF, CUSTOMER.\n\nThe userId variable is auto-set by the Get All Users test script, or set it manually."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role assigned', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "    console.log('New role:', body.data.role);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
